				<set name="multiclass proficiencies">Armas marciais, uma perícia da lista do Patrulheiro, Armaduras Leves, Armaduras Médias, Escudos</set>
			</setters>
			<rules>
				<grant type="Grants" id="ID_INTERNAL_GRANT_MULTICLASS" />
				<select type="Proficiency" name="Proficiência em Perícia (Patrulheiro)" supports="Skill,Ranger"/>
			</rules>
		</multiclass>
