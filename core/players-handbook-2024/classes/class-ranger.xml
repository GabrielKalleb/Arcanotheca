			<select type="Spell" name="Magia (Patrulheiro)" supports="$(spellcasting:list),$(spellcasting:slots)" level="17" number="2" spellcasting="Ranger" />
			<select type="Spell" name="Magia (Patrulheiro)" supports="$(spellcasting:list),$(spellcasting:slots)" level="19" spellcasting="Ranger" />
