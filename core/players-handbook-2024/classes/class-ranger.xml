			<select type="Spell" name="Magia (Patrulheiro)" supports="$(spellcasting:list),$(spellcasting:slots)" level="1" number="2" spellcasting="Ranger" />
			<select type="Spell" name="Magia (Patrulheiro)" supports="$(spellcasting:list),$(spellcasting:slots)" level="2" spellcasting="Ranger" />
			<select type="Spell" name="Magia (Patrulheiro)" supports="$(spellcasting:list),$(spellcasting:slots)" level="3" spellcasting="Ranger" />
			<select type="Spell" name="Magia (Patrulheiro)" supports="$(spellcasting:list),$(spellcasting:slots)" level="4" spellcasting="Ranger" />
			<select type="Spell" name="Magia (Patrulheiro)" supports="$(spellcasting:list),$(spellcasting:slots)" level="5" spellcasting="Ranger" />
			<select type="Spell" name="Magia (Patrulheiro)" supports="$(spellcasting:list),$(spellcasting:slots)" level="7" spellcasting="Ranger" />
			<select type="Spell" name="Magia (Patrulheiro)" supports="$(spellcasting:list),$(spellcasting:slots)" level="9" number="2" spellcasting="Ranger" />
			<select type="Spell" name="Magia (Patrulheiro)" supports="$(spellcasting:list),$(spellcasting:slots)" level="11" spellcasting="Ranger" />
			<select type="Spell" name="Magia (Patrulheiro)" supports="$(spellcasting:list),$(spellcasting:slots)" level="13" spellcasting="Ranger" />
