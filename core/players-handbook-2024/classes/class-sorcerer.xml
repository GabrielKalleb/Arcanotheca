	<element name="NГѓВ­vel 1: ConjuraГѓВ§ГѓВЈo" type="Class Feature" source="PlayerГўв‚¬в„ўs Handbook (2024)" id="ID_WOTC_PHB24_CLASS_FEATURE_SORCERER_SPELLCASTING">
